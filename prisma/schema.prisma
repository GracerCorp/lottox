generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              user    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "account_userId_user_id_fk")

  @@id([provider, providerAccountId], map: "account_provider_providerAccountId_pk")
}

model admins {
  id                   Int                    @id @default(autoincrement())
  email                String                 @unique(map: "admins_email_unique")
  password             String
  created_at           DateTime?              @default(now()) @db.Timestamp(6)
  role                 String                 @default("content_editor")
  prediction_feedback  prediction_feedback[]
  result_verifications result_verifications[]
}

model ai_usage_logs {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider      String
  model         String
  input_tokens  Int       @default(0)
  output_tokens Int       @default(0)
  total_tokens  Int       @default(0)
  cost          String    @default("0")
  context       String?
  metadata      Json?
  created_at    DateTime? @default(now()) @db.Timestamp(6)
}

model api_keys {
  id           String    @id
  owner_id     String
  label        String
  key_prefix   String?
  scope        String?   @default("read-only")
  token_hash   String?
  last_used_at DateTime? @db.Timestamp(6)
  revoked_at   DateTime? @db.Timestamp(6)
  created_at   DateTime? @default(now()) @db.Timestamp(6)
}

model articles {
  id                      String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title                   String
  slug                    String                    @unique(map: "articles_slug_unique")
  excerpt                 String?
  content                 Json
  cover_image             String?
  author_id               String?
  lottery_id              Int?
  summary                 String?
  published               Boolean?                  @default(false)
  published_at            DateTime?                 @db.Timestamp(6)
  tags                    String[]
  view_count              Int?                      @default(0)
  created_at              DateTime?                 @default(now()) @db.Timestamp(6)
  updated_at              DateTime?                 @default(now()) @db.Timestamp(6)
  full_content            String?
  images                  String[]
  meta_title              String?
  meta_description        String?
  canonical_url           String?
  reading_time            Int?
  og_image                String?
  og_title                String?
  related_articles        String[]
  is_featured             Boolean?                  @default(false)
  likes_count             Int?                      @default(0)
  shares_count            Int?                      @default(0)
  comments_count          Int?                      @default(0)
  raw_html                String?
  article_analytics_daily article_analytics_daily[]
  article_comments        article_comments[]
  article_reactions       article_reactions[]
  user                    user?                     @relation(fields: [author_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "articles_author_id_user_id_fk")
  lottery                 lotteries?                @relation(fields: [lottery_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "articles_lottery_id_lottery_jobs_id_fk")

  @@index([author_id])
  @@index([published_at])
}

model background_jobs {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type        String
  payload     Json
  status      String    @default("pending")
  attempts    Int?      @default(0)
  last_error  String?
  next_run_at DateTime? @default(now()) @db.Timestamp(6)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
}

model banners {
  id                Int              @id @default(autoincrement())
  image_url         String
  ai_prompt         String?
  lottery_result_id Int?
  is_active         Boolean          @default(true)
  created_at        DateTime?        @default(now()) @db.Timestamp(6)
  updated_at        DateTime?        @db.Timestamp(6)
  lottery_results   lottery_results? @relation(fields: [lottery_result_id], references: [id], onUpdate: NoAction, map: "banners_lottery_result_id_lottery_results_id_fk")
}

model countries {
  id              Int               @id @default(autoincrement())
  code            String            @unique(map: "countries_code_unique")
  name            String
  flag            String?
  draw_schedule   String?
  odds            String?
  is_active       Boolean?          @default(true)
  created_at      DateTime?         @default(now()) @db.Timestamp(6)
  lotteries       lotteries[]
  lottery_results lottery_results[]
}

model lotteries {
  id                      Int                       @id @default(autoincrement())
  name                    String
  logo                    String?
  currency                String?                   @default("THB")
  is_active               Boolean?                  @default(true)
  country_id              Int?
  created_at              DateTime?                 @default(now()) @db.Timestamp(6)
  updated_at              DateTime?                 @db.Timestamp(6)
  showing_prizes          String[]
  prize_amount_mode       String                    @default("fixed")
  default_prize_amounts   Json?                     @default("{}")
  articles                articles[]
  countries               countries?                @relation(fields: [country_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "lotteries_country_id_countries_id_fk")
  lottery_analytics_cache lottery_analytics_cache[]
  lottery_jobs            lottery_jobs[]
  lottery_results         lottery_results[]
  lottery_subscriptions   lottery_subscriptions[]
  prediction_feedback     prediction_feedback[]
  scraper_logs            scraper_logs[]
}

model email_logs {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String?
  recipient_email String
  subject         String
  type            String    @default("welcome")
  provider        String?
  status          String    @default("sent")
  error_message   String?
  metadata        Json?
  created_at      DateTime? @default(now()) @db.Timestamp(6)
  user            user?     @relation(fields: [user_id], references: [id], onUpdate: NoAction, map: "email_logs_user_id_user_id_fk")

  @@index([created_at])
  @@index([type])
  @@index([user_id])
}

model gamification_logs {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String?
  action     String
  points     Int
  created_at DateTime? @default(now()) @db.Timestamp(6)
  user       user?     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "gamification_logs_user_id_user_id_fk")

  @@index([user_id, created_at], map: "gamification_logs_user_created_idx")
  @@index([user_id])
}

model lottery_jobs {
  id            Int            @id @default(autoincrement())
  name          String
  url           String
  cron_schedule String
  status        String         @default("active")
  created_at    DateTime?      @default(now()) @db.Timestamp(6)
  lottery_id    Int
  scraper_type  String         @default("ai")
  scraper_key   String?
  lotteries     lotteries      @relation(fields: [lottery_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "lottery_jobs_lottery_id_lotteries_id_fk")
  scraper_logs  scraper_logs[]
}

model lottery_results {
  id                                                                            Int                    @id @default(autoincrement())
  draw_date                                                                     String
  draw_period                                                                   String?
  full_data                                                                     Json
  created_at                                                                    DateTime?              @default(now()) @db.Timestamp(6)
  lottery_id                                                                    Int?
  notified_at                                                                   DateTime?              @db.Timestamp(6)
  country_id                                                                    Int?
  data                                                                          Json                   @default("{}")
  updated_at                                                                    DateTime?              @db.Timestamp(6)
  validation_status                                                             String                 @default("pending")
  validation_errors                                                             Json?                  @default("[]")
  validated_at                                                                  DateTime?              @db.Timestamp(6)
  prize_amount_mode                                                             String?
  is_published                                                                  Boolean?               @default(false)
  published_at                                                                  DateTime?              @db.Timestamp(6)
  banners                                                                       banners[]
  countries                                                                     countries?             @relation(fields: [country_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "lottery_results_country_id_countries_id_fk")
  lottery                                                                       lotteries?             @relation(fields: [lottery_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "lottery_results_lottery_id_lottery_jobs_id_fk")
  result_verifications_result_verifications_compared_result_idTolottery_results result_verifications[] @relation("result_verifications_compared_result_idTolottery_results")
  result_verifications_result_verifications_lottery_result_idTolottery_results  result_verifications[] @relation("result_verifications_lottery_result_idTolottery_results")

  @@index([draw_date], map: "draw_date_idx")
  @@index([lottery_id, draw_date], map: "lottery_draw_date_idx")
}

model lottery_subscriptions {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String
  lottery_id Int
  created_at DateTime? @default(now()) @db.Timestamp(6)
  lottery    lotteries @relation(fields: [lottery_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "lottery_subscriptions_lottery_id_lottery_jobs_id_fk")
  user       user      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "subscriptions_user_id_user_id_fk")

  @@index([user_id, lottery_id], map: "user_lottery_idx")
}

model notifications {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String?
  type       String?
  content    String
  read       Boolean?  @default(false)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  user       user?     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "notifications_user_id_user_id_fk")

  @@index([user_id])
}

model platform_settings {
  key         String    @id
  value       String
  description String?
  is_public   Boolean?  @default(false)
  updated_at  DateTime? @default(now()) @db.Timestamp(6)
}

model session {
  sessionToken String   @id
  userId       String
  expires      DateTime @db.Timestamp(6)
  user         user     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "session_userId_user_id_fk")
}

model subscriptions {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id            String?
  stripe_id          String?   @unique(map: "subscriptions_stripe_id_unique")
  status             String?
  current_period_end DateTime? @db.Timestamp(6)
  user               user?     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "subscriptions_user_id_user_id_fk")
}

model user {
  id                    String                  @id
  name                  String?
  email                 String                  @unique(map: "user_email_unique")
  emailVerified         DateTime?               @db.Timestamp(6)
  image                 String?
  password              String?
  points_balance        Int?                    @default(0)
  username              String?                 @unique(map: "user_username_unique")
  title                 String?
  first_name            String?
  last_name             String?
  gender                String?
  phone_number          String?
  country_code          String?
  date_of_birth         DateTime?               @db.Timestamp(6)
  citizen_id            String?
  is_identity_verified  Boolean?                @default(false)
  is_active             Boolean?                @default(true)
  last_sign_in_at       DateTime?               @db.Timestamp(6)
  last_sign_in_method   String?
  push_subscriptions    Json?                   @default("[]")
  created_at            DateTime?               @default(now()) @db.Timestamp(6)
  bio                   String?
  expertise_tags        String[]
  social_links          Json?
  account               account[]
  article_comments      article_comments[]
  article_reactions     article_reactions[]
  articles              articles[]
  email_logs            email_logs[]
  gamification_logs     gamification_logs[]
  lottery_subscriptions lottery_subscriptions[]
  notifications         notifications[]
  session               session[]
  subscriptions         subscriptions[]
  user_addresses        user_addresses[]
}

model user_addresses {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String
  label         String    @default("Home")
  address_line1 String
  subdistrict   String?
  district      String?
  province      String?
  zip_code      String?
  is_default    Boolean?  @default(false)
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  user          user      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "user_addresses_user_id_user_id_fk")

  @@index([user_id])
}

model verificationToken {
  identifier String
  token      String
  expires    DateTime @db.Timestamp(6)

  @@id([identifier, token], map: "verificationToken_identifier_token_pk")
}

model result_verifications {
  id                                                                       Int              @id @default(autoincrement())
  lottery_result_id                                                        Int
  compared_result_id                                                       Int?
  status                                                                   String           @default("pending")
  match_percentage                                                         Int?
  diff_details                                                             Json?            @default("{}")
  verified_by                                                              Int?
  notes                                                                    String?
  created_at                                                               DateTime?        @default(now()) @db.Timestamp(6)
  updated_at                                                               DateTime?        @db.Timestamp(6)
  verified_at                                                              DateTime?        @db.Timestamp(6)
  chosen_data                                                              Json?
  chosen_source                                                            String?
  lottery_results_result_verifications_compared_result_idTolottery_results lottery_results? @relation("result_verifications_compared_result_idTolottery_results", fields: [compared_result_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "result_verifications_compared_result_id_lottery_results_id_fk")
  lottery_results_result_verifications_lottery_result_idTolottery_results  lottery_results  @relation("result_verifications_lottery_result_idTolottery_results", fields: [lottery_result_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "result_verifications_lottery_result_id_lottery_results_id_fk")
  admins                                                                   admins?          @relation(fields: [verified_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "result_verifications_verified_by_admins_id_fk")

  @@index([lottery_result_id], map: "verification_lottery_result_idx")
  @@index([status], map: "verification_status_idx")
}

model article_analytics_daily {
  id                 Int       @id @default(autoincrement())
  article_id         String    @db.Uuid
  date               String
  views              Int?      @default(0)
  avg_active_seconds Int?      @default(0)
  scroll_completes   Int?      @default(0)
  bounce_count       Int?      @default(0)
  created_at         DateTime? @default(now()) @db.Timestamp(6)
  updated_at         DateTime? @db.Timestamp(6)
  articles           articles  @relation(fields: [article_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "article_analytics_daily_article_id_articles_id_fk")

  @@unique([article_id, date], map: "article_analytics_daily_article_date_idx")
}

model article_comments {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  article_id String    @db.Uuid
  user_id    String?
  content    String
  status     String    @default("approved")
  parent_id  String?   @db.Uuid
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @db.Timestamp(6)
  articles   articles  @relation(fields: [article_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "article_comments_article_id_articles_id_fk")
  user       user?     @relation(fields: [user_id], references: [id], onUpdate: NoAction, map: "article_comments_user_id_user_id_fk")

  @@index([article_id])
  @@index([parent_id])
  @@index([user_id])
}

model article_reactions {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  article_id    String    @db.Uuid
  user_id       String?
  session_id    String?
  reaction_type String    @default("like")
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  articles      articles  @relation(fields: [article_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "article_reactions_article_id_articles_id_fk")
  user          user?     @relation(fields: [user_id], references: [id], onUpdate: NoAction, map: "article_reactions_user_id_user_id_fk")

  @@unique([article_id, session_id], map: "article_reactions_article_session_idx")
  @@index([article_id, user_id], map: "article_reactions_article_user_idx")
}

model lottery_analytics_cache {
  id          Int        @id @default(autoincrement())
  lottery_id  Int?
  category    String
  period      Int
  type        String
  payload     Json
  computed_at DateTime?  @default(now()) @db.Timestamp(6)
  created_at  DateTime?  @default(now()) @db.Timestamp(6)
  lotteries   lotteries? @relation(fields: [lottery_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "lottery_analytics_cache_lottery_id_lotteries_id_fk")

  @@index([lottery_id, category, type, period], map: "analytics_cache_lookup_idx")
}

model prediction_feedback {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lottery_id      Int?
  draw_date       String
  prediction_type String
  predicted_data  Json
  actual_data     Json
  rating          String
  match_count     Int?
  total_predicted Int?
  notes           String?
  admin_id        Int?
  created_at      DateTime?  @default(now()) @db.Timestamp(6)
  admins          admins?    @relation(fields: [admin_id], references: [id], onUpdate: NoAction, map: "prediction_feedback_admin_id_admins_id_fk")
  lotteries       lotteries? @relation(fields: [lottery_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "prediction_feedback_lottery_id_lotteries_id_fk")

  @@index([lottery_id, draw_date], map: "prediction_feedback_lottery_draw_idx")
}

model scraper_logs {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  job_id        Int?
  lottery_id    Int?
  status        String
  attempts      Int           @default(1)
  error_details String?
  duration_ms   Int?
  started_at    DateTime?     @default(now()) @db.Timestamp(6)
  completed_at  DateTime?     @db.Timestamp(6)
  created_at    DateTime?     @default(now()) @db.Timestamp(6)
  lottery_jobs  lottery_jobs? @relation(fields: [job_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "scraper_logs_job_id_lottery_jobs_id_fk")
  lotteries     lotteries?    @relation(fields: [lottery_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "scraper_logs_lottery_id_lotteries_id_fk")
}
